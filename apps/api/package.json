{
  "name": "@proveria/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:eval-producer": "tsx scripts/seed-eval-producer.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .turbo",
    "lint": "echo 'TODO(lint): wire eslint'",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/sensible": "^6.0.2",
    "@proveria/audit": "workspace:*",
    "@proveria/crypto-core": "workspace:*",
    "@proveria/db": "workspace:*",
    "@proveria/evidence-export": "workspace:*",
    "@proveria/manifest": "workspace:*",
    "@proveria/proofs": "workspace:*",
    "@proveria/receipt": "workspace:*",
    "@proveria/shared-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.717.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.10",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
