{
  "name": "@proveria/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "dev": "node scripts/build.cjs && node scripts/launch-electron.cjs",
    "dev:renderer": "vite",
    "build": "node scripts/build.cjs",
    "build:renderer": "vite build",
    "start": "node scripts/launch-electron.cjs",
    "smoke:happy-path": "tsx scripts/smoke-happy-path.ts",
    "smoke:visual": "node scripts/build.cjs && node scripts/electron-visual-qa.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
    "test:unit": "vitest run renderer/lib/content-proof.test.ts",
    "clean": "rm -rf dist .turbo release dist-electron",
    "lint": "echo 'TODO(lint): wire eslint'",
    "test": "node scripts/build.cjs && node scripts/electron-smoke.cjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@proveria/crypto-core": "workspace:*",
    "@proveria/manifest": "workspace:*",
    "@proveria/ocr": "workspace:*",
    "@proveria/shared-types": "workspace:*",
    "@proveria/shingling": "workspace:*",
    "@proveria/ui": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.62.10",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tesseract.js": "^7.0.0",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "esbuild": "^0.24.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.7",
    "typescript": "^5.7.2"
  }
}
