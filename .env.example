# Copy this file to .env for local development. .env is gitignored.
# These defaults are for local Docker Compose only — never use them in pilot/prod.

# ---- Postgres ----
POSTGRES_USER=proveria
POSTGRES_PASSWORD=proveria_dev
POSTGRES_DB=proveria
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO (S3-compatible local object store) ----
MINIO_ROOT_USER=proveria
MINIO_ROOT_PASSWORD=proveria_dev_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ARTIFACTS_BUCKET=proveria-artifacts

# ---- Application connection strings (consumed by apps in later milestones) ----
DATABASE_URL=postgres://proveria:proveria_dev@localhost:5432/proveria
REDIS_URL=redis://localhost:6379

# ---- S3 / object storage (MinIO locally, real S3 in pilot/prod) ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=proveria
S3_SECRET_KEY=proveria_dev_minio
S3_FORCE_PATH_STYLE=true
S3_ARTIFACTS_BUCKET=proveria-artifacts

# ---- Runtime ----
NODE_ENV=development
